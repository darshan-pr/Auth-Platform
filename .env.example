# ==================== Database ====================
# PostgreSQL connection string
# Local: postgresql://user:password@localhost:5432/auth_db
# Railway: Automatically provided by Railway PostgreSQL service
DATABASE_URL=postgresql://user:password@localhost:5432/auth_db

# ==================== Redis ====================
# Redis connection string  
# Local: redis://localhost:6379
# Railway: Automatically provided by Railway Redis service
REDIS_URL=redis://localhost:6379

# ==================== JWT Configuration ====================
# Secret key for JWT signing
# Generate with: openssl rand -hex 32
# IMPORTANT: Use a strong, unique secret in production!
JWT_SECRET=your-secret-key-here

# ==================== SMTP Configuration ====================
# Email server settings for OTP delivery
# For Gmail: Enable 2FA and create an App Password
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# ==================== CORS Configuration (Optional) ====================
# Comma-separated list of allowed origins
# Development: Use * or leave empty
# Production: Specify exact domains
# ALLOWED_ORIGINS=https://yourdomain.com,https://admin.yourdomain.com

# ==================== Environment (Optional) ====================
# Railway automatically sets RAILWAY_ENVIRONMENT=production
# ENVIRONMENT=development
